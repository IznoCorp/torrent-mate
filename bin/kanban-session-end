#!/usr/bin/env python3
"""Thin shim for the ``kanban-session-end`` agent helper (DESIGN §8.3).

Delegates to :func:`kanbanmate.bin.kanban_session_end.main` so the session-end logic (mark the
ticket idle + release its cap slot) lives in the importable engine and this top-level file stays a
one-line entry point. The dispatcher wires it as ``claude … ; kanban-session-end <issue>`` so it
fires whether the agent exited cleanly, crashed, or was interrupted.
"""

import sys

from kanbanmate.bin.kanban_session_end import main

if __name__ == "__main__":
    sys.exit(main())
