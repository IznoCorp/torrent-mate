// Synthetic broken providers config — triggers all 6 ConfigIssue families
// simultaneously when validated against a Settings object that only has
// fake TMDB+TVDB keys.
//
// Family 1 — unknown_provider: "nobody" does not exist in PROVIDER_CLASSES.
// Family 2 — empty_chain_section: MovieDetailsProvider has zero providers.
// Family 3 — protocol_mismatch: tmdb listed under IDValidator but TMDBClient
//            does NOT implement IDValidator (confirmed by pre-flight check).
// Family 4 — missing_credentials: "imdb" is listed but no IMDB credentials
//            exist in the test Settings object.
// Family 5 — locked_capability_orphan: tvdb is listed under KeywordProvider
//            but TVDBClient does NOT implement KeywordProvider, and it is the
//            only provider in that section.
// Family 6 — idcrossref_cycle: IDCrossRef config has tmdb → tvdb → tmdb,
//            forming a detection cycle without terminal node.
//
// Used by: tests/unit/api/metadata/registry/test_registry_validation.py
//          test_all_six_issue_families_in_one_error (ACC-05b)
{
  Searchable: { nobody: 1, tvdb: 2, tmdb: 3 },
  MovieDetailsProvider: {},
  TvDetailsProvider: { tvdb: 1, tmdb: 2 },
  EpisodeFetcher: { tvdb: 1, tmdb: 2 },
  RatingProvider: {},
  ArtworkProvider: { tmdb: 1 },
  KeywordProvider: { tvdb: 1 },
  VideoProvider: { tmdb: 1 },
  RecommendationProvider: { imdb: 1 },
  IDValidator: { tmdb: 1 },
  IDCrossRef: { tmdb: 1, tvdb: 2 },
}
