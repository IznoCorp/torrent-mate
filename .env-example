# KanbanMate UI — config interface login. Copy to `.env` and fill in (`.env` is gitignored).
# Loaded by `kanban config serve`. EMPTY KANBAN_MATE_UI_PASSWORD = no login (open; loopback/dev only).
KANBAN_MATE_UI_PORT=8796
KANBAN_MATE_UI_LOGIN=admin
KANBAN_MATE_UI_PASSWORD=
# Optional: stable session-signing secret (hex). Unset = random per restart (sessions drop on restart).
KANBAN_MATE_UI_SESSION_SECRET=
