{
  "plugins": ["react"],
  "rules": {
    "react/forbid-elements": [
      "error",
      {
        "forbid": [
          {
            "element": "img",
            "message": "Use the DS <MediaPoster> (media) or <BrandMark> (brand). A raw <img> bypasses the design system's lazy loading, branded fallback, and alt handling."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/components/ds/**", "**/components/ui/**"],
      "rules": {
        "react/forbid-elements": "off"
      }
    }
  ],
  "ignorePatterns": ["dist", "node_modules"]
}
