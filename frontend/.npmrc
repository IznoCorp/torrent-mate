# npm install/ci resolution policy for the TorrentMate frontend.
#
# `openapi-typescript@7` declares a `typescript@^5.x` peer, but this project runs
# `typescript@^6` (only used to *generate* `src/api/schema.d.ts`, never at
# runtime). npm 7+ treats that mismatch as a hard ERESOLVE error and aborts
# `npm ci`, breaking CI and both deploy scripts. The committed lockfile was
# produced with legacy peer resolution, so pin it here to keep `npm ci`
# deterministic and green until openapi-typescript ships a TS 6 peer range.
legacy-peer-deps=true
