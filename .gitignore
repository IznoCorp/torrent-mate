# ===========================================
# Sorting folders and scripts - fully ignored
# ===========================================
[0-9][0-9][0-9]-*/

# ===========================================
# Root-level media (before torrent-sort dispatch)
# Already covered by extension rules above
# ===========================================

# ===========================================
# Environment / Secrets
# ===========================================
.env
.env.*
!.env.example

# ===========================================
# Python
# ===========================================
.venv/
__pycache__/
*.pyc
*.pyo
*.pkl
*.egg-info/
dist/
build/
.pytest_cache/
htmlcov/
.coverage

# ===========================================
# Logs (structured JSON, non-committed)
# ===========================================
logs/

# ===========================================
# IDE / Editor
# ===========================================
.vscode/

# ===========================================
# Backups and caches
# ===========================================
*.bak

# ===========================================
# E2E Tests
# ===========================================
e2e-test-registry-*.json

# ===========================================
# Pipeline run logs (diagnostic output)
# ===========================================
docs/pipeline-runs/

# ===========================================
# Claude Code
# ===========================================
# .claude/ is its own git repo (shared config) — do NOT embed it
.claude/
# .claude-old/ is a backup — ignore
.claude-old/
.personalscraper/
# V15 runtime state (library index, tracker, lock, analysis results, .v14.bak backups)
.data/

# V15: personal config (paths + preferences, no secrets but gitignored for privacy)
config.json5
config.json5.v15.bak
# TMDB keywords cache
tmdb_keywords_cache.json

# launchd plist is generated from .plist.template via scripts/install-launchd.sh
# and installed to ~/Library/LaunchAgents/ — never commit the rendered copy
com.personalscraper.pipeline.plist
