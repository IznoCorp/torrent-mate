# Portable Claude config — its own git repo, never tracked by this repo
.claude/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv*
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
# pyenv interpreter pin (local dev choice, not tracked — DESIGN phase-10 §10.2)
.python-version

# Runtime state (KanbanMate writes here, never in-repo)
.kanban/

# OS / editor
.DS_Store
*.swp
# Generated per-host by `kanban install` (absolute pyenv path baked in — not portable)
ecosystem.config.js
.superpowers/

# bridge config SPA — build output (CI-built, shipped in wheel) + node deps
src/kanbanmate/webui/
web/node_modules/

# Operator credentials for the config UI login (KANBAN_MATE_UI_*) — never commit
.env

# Generated per-worktree by the daemon (perms.write_mcp_registration) — registers the
# project-scoped `kanban` MCP server with HOST-LOCAL absolute --root paths + the project node id.
# Claude reads it from the worktree root, but the worktree shares .git with the WIP branch, so a
# dev/merge agent's `git add -A` would otherwise bake host-local state into a PR. Never commit it.
.mcp.json
