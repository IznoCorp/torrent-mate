# ===========================================
# macOS
# ===========================================
.DS_Store

# ===========================================
# Media files (safety net - never commit these)
# ===========================================
*.mkv
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mpg
*.mpeg
*.m4v
*.webm
*.ts
*.mp3
*.flac
*.wav
*.ogg
*.aac
*.m4a
*.wma
*.opus
*.nfo
*.srt
*.sub
*.vtt
*.idx
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp
*.iso
*.img
*.dmg
*.torrent
*.epub
*.mobi
*.pdf
*.cbr
*.cbz
*.apk
*.exe
*.msi
*.app
*.rar
*.zip
*.7z
*.tar
*.gz

# ===========================================
# Sorting folders - track structure only
# ===========================================
# Ignore all content inside sorting folders
001-MOVIES/*
002-TVSHOWS/*
003-EBOOKS/*
004-AUDIO/*
005-APPS/*
006-ANDROID/*
097-TEMP/*
098-AUTRES/*

# But keep the folders themselves
!001-MOVIES/.gitkeep
!002-TVSHOWS/.gitkeep
!003-EBOOKS/.gitkeep
!004-AUDIO/.gitkeep
!005-APPS/.gitkeep
!006-ANDROID/.gitkeep
!097-TEMP/.gitkeep
!098-AUTRES/.gitkeep

# ===========================================
# Root-level media (before torrent-sort dispatch)
# Already covered by extension rules above
# ===========================================

# ===========================================
# Environment / Secrets
# ===========================================
.env
.env.*
!.env.example

# ===========================================
# Python
# ===========================================
.venv/
__pycache__/
*.pyc
*.pyo
*.pkl
*.egg-info/
dist/
build/
.pytest_cache/
htmlcov/
.coverage

# ===========================================
# Logs (structured JSON, non-committed)
# ===========================================
logs/

# ===========================================
# IDE / Editor
# ===========================================
.vscode/

# ===========================================
# Backups and caches
# ===========================================
*.bak
099-SCRIPTS/plex/contents.json

# ===========================================
# E2E Tests
# ===========================================
e2e-test-registry-*.json

# ===========================================
# Pipeline run logs (diagnostic output)
# ===========================================
docs/pipeline-runs/

# ===========================================
# Claude Code
# ===========================================
# .claude/ is its own git repo (shared config) — do NOT embed it
.claude/
# .claude-old/ is a backup — ignore
.claude-old/
.personalscraper/
