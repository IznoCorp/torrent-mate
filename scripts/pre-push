#!/usr/bin/env bash
# Pre-push hook: runs CI-equivalent fast checks + tests before every push.
# Bypass with: git push --no-verify (use sparingly)
#
# Checks:
#   1. ruff check        — linting + import sorting
#   2. ruff format check — code style (no rewrite)
#   3. logging audit     — structlog convention compliance
#   4. mypy              — static type checking
#   5. pytest            — full test suite
#
# Mirrors the CI pipeline (.github/workflows/ci.yml) stage 1 + tests.

set -euo pipefail

# Git invokes hooks with GIT_DIR/GIT_WORK_TREE/GIT_INDEX_FILE set in the
# environment so a hook's own git commands target the right repo by default.
# That leaks into pytest: tests that build a synthetic "isolated" git repo in
# a tmp_path (tests/scripts/test_phase_gate.py and friends) run `git -C
# <tmp_path> commit` expecting it to touch only the tmp repo, but GIT_DIR /
# GIT_WORK_TREE override -C and silently redirect the commit into the REAL
# repo this hook is running in instead — clobbering whatever branch is
# checked out (observed: it overwrote a checked-out branch's history with the
# test's synthetic "chore: init" commits). Unset before running anything.
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_PREFIX

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

NUM_CHECKS=5
failures=0
total=0

run_check() {
  local label="$1"; shift
  total=$((total + 1))
  printf "${YELLOW}[%s/%s]${NC} %s ... " "$total" "$NUM_CHECKS" "$label"
  if "$@" > /dev/null 2>&1; then
    printf "${GREEN}OK${NC}\n"
  else
    printf "${RED}FAILED${NC}\n"
    "$@" 2>&1 | sed 's/^/    /'
    failures=$((failures + 1))
  fi
}

echo ""
echo "┌──────────────────────────────────────────────┐"
echo "│  Pre-push CI checks (fast + tests)           │"
echo "│  Bypass: git push --no-verify                │"
echo "└──────────────────────────────────────────────┘"
echo ""

run_check "ruff check"               python -m ruff check personalscraper/ tests/
run_check "ruff format --check"      python -m ruff format --check personalscraper/ tests/
run_check "logging audit"            python scripts/check_logging.py personalscraper/
run_check "mypy"                     python -m mypy personalscraper/
run_check "pytest"                   python -m pytest -v -n auto

echo ""
if [[ "$failures" -eq 0 ]]; then
  printf "${GREEN}All %s checks passed. Pushing...${NC}\n\n" "$total"
  exit 0
else
  printf "${RED}%s/%s check(s) failed. Push aborted.${NC}\n" "$failures" "$total"
  echo "Fix the issues above or bypass with: git push --no-verify"
  echo ""
  exit 1
fi
