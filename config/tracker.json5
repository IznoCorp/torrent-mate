{
  // PROVIDER_CREDS: lacale → LACALE_API_KEY, c411 → C411_API_KEY
  // PROVIDER_CREDS: torr9 → TORR9_USERNAME + TORR9_PASSWORD (JWT login)
  // PROVIDER_OPTIONAL_SECRETS (non-gating): lacale → LACALE_PASSKEY, c411 → C411_PASSKEY,
  //   torr9 → TORR9_PASSKEY (RSS freeleech radar R1 follow-on)
  tracker: {
    providers: {
      lacale: { enabled: false, cross_seed: false }, // deprecated + unreachable (la-cale.space down) — disabled to stop CircuitOpenError crashing grab
      c411: {
        enabled: true,
        cross_seed: false,
        economy: {
          target_ratio: 2.0,
          min_ratio: 1.0,
          min_seed_time: "72h",
          hit_and_run_grace: "0h",
        },
      },
      torr9: {
        enabled: true,
        cross_seed: false,
        economy: {
          target_ratio: 2.0,
          min_ratio: 1.0,
          min_seed_time: "72h",
          hit_and_run_grace: "0h",
        },
      },
    },
    priority: ["c411", "torr9"],
    max_total_results: 50,
    max_per_tracker: 30,
    timeout_per_tracker: 15,
  },
}
