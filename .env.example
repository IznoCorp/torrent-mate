# ── qBittorrent ──────────────────────────────
QBIT_HOST=localhost
QBIT_PORT=8080
QBIT_USERNAME=admin
QBIT_PASSWORD=

# ── TMDB / TVDB ──────────────────────────────
TMDB_API_KEY=
TVDB_API_KEY=

# ── Scraper ──────────────────────────────────
SCRAPER_LANGUAGE=fr-FR
SCRAPER_FALLBACK_LANGUAGE=en-US
SCRAPER_PREFER_LOCAL_TITLE=true
ARTWORK_LANGUAGE=en

# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Thresholds ───────────────────────────────
MIN_FREE_SPACE_STAGING_GB=20
MIN_FREE_SPACE_DISK_GB=100

# ── Circuit Breaker ──────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN=300

# ── Monitoring ───────────────────────────────
HEALTHCHECK_URL=

# ── Trailers (yt-dlp) ────────────────────────
# Requires ffmpeg on PATH: brew install ffmpeg / apt-get install ffmpeg
# Cookie file (Netscape format, must be on APFS-native path, mode 600)
YOUTUBE_COOKIES_FILE=
# Browser profile for live cookie extraction (e.g. firefox, chrome, safari)
YOUTUBE_COOKIES_FROM_BROWSER=
