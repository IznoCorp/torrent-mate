# ── qBittorrent ──────────────────────────────
QBIT_HOST=localhost
QBIT_PORT=8080
QBIT_USERNAME=admin
QBIT_PASSWORD=

# ── Paths ────────────────────────────────────
TORRENT_COMPLETE_DIR=/path/to/torrents/complete
STAGING_DIR=/path/to/staging
DISK1_DIR=/path/to/disk1/medias
DISK2_DIR=/path/to/disk2/medias
DISK3_DIR=/path/to/disk3/medias
DISK4_DIR=/path/to/disk4/medias

# ── TMDB / TVDB ──────────────────────────────
TMDB_API_KEY=
TVDB_API_KEY=

# ── Scraper ──────────────────────────────────
SCRAPER_LANGUAGE=fr-FR
SCRAPER_FALLBACK_LANGUAGE=en-US
SCRAPER_PREFER_LOCAL_TITLE=true

# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Thresholds ───────────────────────────────
MIN_FREE_SPACE_STAGING_GB=20
MIN_FREE_SPACE_DISK_GB=100

# ── Directory Names (defaults shown) ─────────
# INGEST_DIR_NAME=097-TEMP
# DATA_DIR_NAME=.personalscraper
# MOVIES_DIR_NAME=001-MOVIES
# TVSHOWS_DIR_NAME=002-TVSHOWS
# EBOOKS_DIR_NAME=003-EBOOKS
# AUDIO_DIR_NAME=004-AUDIO
# APPS_DIR_NAME=005-APPS
# OTHER_DIR_NAME=098-AUTRES

# ── Circuit Breaker (V8) ─────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN=300

# ── Monitoring ───────────────────────────────
HEALTHCHECK_URL=
