# ── qBittorrent ──────────────────────────────
# Host and port live in config/torrent.json5 (clients.qbittorrent.host / .port).
# Only credentials belong here.
QBIT_USERNAME=admin
QBIT_PASSWORD=

# ── TMDB / TVDB ──────────────────────────────
TMDB_API_KEY=
TVDB_API_KEY=

# ── Provider registry — optional credentials ─
# Trakt client ID (app-only auth). Enables RecommendationProvider + Searchable/Details.
TRAKT_CLIENT_ID=

# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Monitoring ───────────────────────────────
HEALTHCHECK_URL=

# ── Trailers (yt-dlp) ────────────────────────
# Requires ffmpeg on PATH: brew install ffmpeg / apt-get install ffmpeg

# YouTube Data API v3 key (primary trailer search path).
# Leave blank to fall back to yt-dlp `ytsearch1` (slower, no quota). The primary path
# costs 100 quota units per search.list call (default daily quota = 10 000 units).
# Get a key at: https://console.developers.google.com/apis/api/youtube.googleapis.com
YOUTUBE_API_KEY=

# YouTube cookies for yt-dlp bot-detection bypass (optional)
# Option A: static Netscape-format cookies.txt (must be on APFS-native storage, mode 600)
YOUTUBE_COOKIES_FILE=
# Option B: live extraction from a browser profile
# Valid values: firefox, chrome, chromium, edge, opera, brave, safari
YOUTUBE_COOKIES_FROM_BROWSER=

# ── OMDB ─────────────────────────────────────
# OMDb API key (required for OMDB/IMDb/Rotten Tomatoes ratings backfill
# during library-scan).  Free tier = 1000 req/day.
# Get a key at: http://www.omdbapi.com/apikey.aspx
# Leave blank to skip ratings backfill entirely.
OMDB_API_KEY=

# Daily request limit override (default: 1000, the OMDB free tier quota).
# Patreon $1 tier = 100 000 req/day.  Only active when OMDB_API_KEY is set.
# OMDB_DAILY_LIMIT=1000

# ── Library Analyzer ─────────────────────────
# Max worker threads for library-analyze video analysis (default: 4).
# The cap of 4 targets NTFS-USB mechanical drives to avoid I/O saturation.
# Override for SSD or NVMe libraries with higher concurrency.
# LIBRARY_ANALYZER_MAX_WORKERS=4

# ── TorrentMate Web UI ────────────────────────
# Password hash for web UI login (generated by `personalscraper web set-password`).
# Uses hashlib.scrypt with format: scrypt$N$r$p$salt$hash
WEB_PASSWORD_HASH=
# HS256 secret key for JWT session tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
WEB_JWT_SECRET=
# Deployment role for the web daemon (config-editor S4). "staging" makes every
# config write endpoint return 403 (read-only editor); anything else = prod.
# Set per PM2 app in ecosystem.config.js, not here.
# PERSONALSCRAPER_WEB_ROLE=staging
# PM2 app name targeted by POST /api/config/restart-web (config-editor S4).
# Unset = the restart endpoint returns 404 and the button is hidden in the UI.
# PERSONALSCRAPER_PM2_NAME=torrentmate-web

# ── Tracker passkeys (optional, non-gating — tracker-economy RP2) ──────────
# A missing passkey never deactivates a tracker. Used only by Vague-5
# seeding consumers (Ratio C1, Seed-Safety O2) once implemented.
# LACALE_PASSKEY=
# C411_PASSKEY=

# ── Maintenance runner (internal) ────────────────
# Set internally by the web maintenance action spawner for the runner
# subprocess (personalscraper/web/maintenance/runner.py).
# Not operator-configured.
# PERSONALSCRAPER_MAINT_COMMAND=
# PERSONALSCRAPER_MAINT_DRY_RUN=
# PERSONALSCRAPER_MAINT_OPTIONS_JSON=

# ── Decisions runner (internal) ──────────────────
# Set internally by the web decision-resolve spawner for the runner
# subprocess (personalscraper/web/decisions/runner.py).
# Not operator-configured.
# PERSONALSCRAPER_DECISION_ID=
# PERSONALSCRAPER_DECISION_PROVIDER=
# PERSONALSCRAPER_DECISION_PROVIDER_ID=
# PERSONALSCRAPER_DECISION_VIA=

# ── Grab runner (internal) ───────────────────────
# Set internally by the web per-series grab-trigger spawner for the runner
# subprocess (personalscraper/web/acquisition/runner.py).
# Not operator-configured.
# PERSONALSCRAPER_GRAB_FOLLOWED_ID=

# Resolve queue: max seconds a web scrape-resolve waits for pipeline.lock
# before giving up (visible 'queue' state; default 1800 = 30 min).
PERSONALSCRAPER_RESOLVE_QUEUE_TIMEOUT=1800
